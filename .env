# Development Environment Configuration
# For production, customize these values per robot instance

ROBOT_MODEL=mowbot_gazebo_modelv3
SENSOR_MODEL=mowbot_gazebo_sensor_kit
MANUFACTURER=MowbotTech

# Robot ID (REQUIRED) - Unique identifier for this robot
# Must be unique across your fleet
# Development: dev_001, mowbot_dev
# Production: mowbot_001, mowbot_002, etc.
ROBOT_ID=dev_001

DATA_PATH=/workspaces/mowbot/mowbot_data
ROS_DOMAIN_ID=0
